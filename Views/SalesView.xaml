<!-- ============================================================
     Views/SalesView.xaml
     ============================================================
     ضعه في: StoreApp/Views/SalesView.xaml
     المسؤول: العضو 3 (نقطة البيع)

     RelativeSource في RemoveItemCommand:
       الزر "✕" داخل DataTemplate يفقد DataContext الأصلي
       (يصبح DataContext = CartItemModel نفسه).
       RelativeSource AncestorType=UserControl يرجع لـ
       DataContext الأصلي (SalesViewModel) للوصول للـ Command.
     ============================================================ -->
<UserControl x:Class="StoreApp.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <!-- ===== العمود الأيسر: بحث + نتائج ===== -->
        <Grid Grid.Column="0" Margin="0,0,16,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="🛒 نقطة البيع"
                       FontSize="22" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,16"/>

            <TextBox Grid.Row="1"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <!-- نتائج البحث — ضغط Enter يضيف للسلة -->
            <DataGrid Grid.Row="2"
                      ItemsSource="{Binding SearchResults}"
                      SelectedItem="{Binding SelectedSearchResult, Mode=TwoWay}">
                <DataGrid.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding AddToCartCommand}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="اسم المنتج"  Binding="{Binding P_Name}" Width="*"   IsReadOnly="True"/>
                    <DataGridTextColumn Header="السعر"       Binding="{Binding Price, StringFormat={}{0:C2}}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="المتاح"      Binding="{Binding StockQuantity}" Width="70" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- ===== العمود الأيمن: السلة + الإجماليات ===== -->
        <Border Grid.Column="1" Background="White" CornerRadius="8"
                BorderBrush="#DDD" BorderThickness="1" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding ItemCount, StringFormat='السلة ({0} قطعة)'}"
                           FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>

                <!-- بنود السلة -->
                <ListView Grid.Row="1" ItemsSource="{Binding CartItems}"
                          BorderThickness="0" Background="Transparent">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="0,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding ProductName}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding UnitPrice, StringFormat={}{0:C2}}"
                                                   FontSize="11" Foreground="#999"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="4,0">
                                        <TextBlock Text="{Binding Quantity, StringFormat='×{0}'}"
                                                   FontWeight="Bold" FontSize="12" HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding LineTotal, StringFormat={}{0:C2}}"
                                                   FontSize="11" Foreground="#27AE60" HorizontalAlignment="Right"/>
                                    </StackPanel>
                                    <!-- زر حذف البند -->
                                    <Button Grid.Column="2" Content="✕"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#E74C3C" FontWeight="Bold" Cursor="Hand"
                                            Command="{Binding DataContext.RemoveItemCommand,
                                                      RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- الإجماليات (Calculated Fields) -->
                <Border Grid.Row="2" BorderBrush="#EEE" BorderThickness="0,1,0,0" Padding="0,12,0,8">
                    <StackPanel>
                        <Grid Margin="0,3">
                            <TextBlock Text="المجموع الجزئي:" Foreground="#555"/>
                            <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C2}}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,3">
                            <TextBlock Text="ضريبة (14%):" Foreground="#555"/>
                            <TextBlock Text="{Binding Tax, StringFormat={}{0:C2}}" HorizontalAlignment="Right"/>
                        </Grid>
                        <Grid Margin="0,8,0,0">
                            <TextBlock Text="الإجمالي:" FontSize="15" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Total, StringFormat={}{0:C2}}"
                                       HorizontalAlignment="Right" FontSize="15"
                                       FontWeight="Bold" Foreground="#27AE60"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- أزرار الدفع والإلغاء -->
                <StackPanel Grid.Row="3" Margin="0,8,0,0">
                    <Button Content="✅  إتمام الدفع"
                            Command="{Binding CheckoutCommand}"
                            Style="{StaticResource SuccessButton}"
                            Height="44" FontSize="15" Margin="0,0,0,6"/>
                    <Button Content="🗑  إلغاء السلة"
                            Command="{Binding ClearCartCommand}"
                            Style="{StaticResource DangerButton}" Height="36"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
