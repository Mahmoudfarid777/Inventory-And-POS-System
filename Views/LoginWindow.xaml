
<Window x:Class="StoreApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StoreApp.ViewModels"
        Title="Store Management — تسجيل الدخول"
        Width="400" Height="440"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="White">

    <Window.DataContext>
        <vm:LoginViewModel/>
    </Window.DataContext>

    <Border Padding="40">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="🏪"                 FontSize="42" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Store Management"   FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Foreground="#2C3E50" Margin="0,0,0,4"/>
            <TextBlock Text="Transaction Processing System"
                       HorizontalAlignment="Center" Foreground="#999" FontSize="12" Margin="0,0,0,28"/>

            <TextBlock Text="اسم المستخدم" FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox   Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                       Margin="0,0,0,14"/>

            <TextBlock Text="كلمة السر"    FontSize="13" Foreground="#555" Margin="0,0,0,4"/>
            <PasswordBox x:Name="PwdBox"  Height="34" Margin="0,0,0,8"
                         FontSize="13" BorderBrush="#BDC3C7" BorderThickness="1"/>

            <TextBlock Text="{Binding ErrorMessage}" Foreground="#E74C3C"
                       FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>
			
			<Button Content="دخول"
                             Click="LoginButton_Click"
                            Style="{StaticResource PrimaryButton}"
                            Height="42" FontSize="15"/>



            <TextBlock Text="بيانات تجريبية: admin/admin123  أو  cashier/cashier123"
                       HorizontalAlignment="Center" Foreground="#BBB"
                       FontSize="11" Margin="0,14,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
