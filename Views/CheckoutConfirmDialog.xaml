
<Window x:Class="StoreApp.Views.CheckoutConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="تأكيد الدفع"
        Width="380" Height="320"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Border Padding="28">
        <StackPanel>
            <TextBlock Text="ملخص الفاتورة" FontSize="18" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,20"/>
            <Grid Margin="0,4">
                <TextBlock Text="المجموع الجزئي:" Foreground="#555"/>
                <TextBlock x:Name="SubtotalText" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>
            <Grid Margin="0,4">
                <TextBlock Text="ضريبة 14%:" Foreground="#555"/>
                <TextBlock x:Name="TaxText" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>
            <Separator Margin="0,10"/>
            <Grid Margin="0,4">
                <TextBlock Text="الإجمالي:" FontSize="16" FontWeight="Bold"/>
                <TextBlock x:Name="TotalText" HorizontalAlignment="Right"
                           FontSize="16" FontWeight="Bold" Foreground="#27AE60"/>
            </Grid>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="إلغاء" IsCancel="True" Width="90" Height="34" Margin="0,0,10,0"/>
                <Button Content="✅ تأكيد الدفع" IsDefault="True"
                        Style="{StaticResource SuccessButton}"
                        Width="120" Height="34"
                        Click="Confirm_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
