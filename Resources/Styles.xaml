<!-- ============================================================
     Resources/Styles.xaml
     ============================================================
     ضعه في: StoreApp/Resources/Styles.xaml
     المسؤول: العضو 5 (UI/UX)

     هذا الملف = "بنك الألوان والأنماط" للمشروع كله.
     أي زر أو حقل في أي شاشة يستخدم StaticResource من هنا
     بدل تكرار الألوان والأحجام في كل XAML.
     ============================================================ -->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== ألوان ===== -->
    <SolidColorBrush x:Key="PrimaryBrush"     Color="#2C3E50"/>
    <SolidColorBrush x:Key="AccentBrush"      Color="#3498DB"/>
    <SolidColorBrush x:Key="SuccessBrush"     Color="#27AE60"/>
    <SolidColorBrush x:Key="DangerBrush"      Color="#E74C3C"/>
    <SolidColorBrush x:Key="SidebarBrush"     Color="#2C3E50"/>
    <SolidColorBrush x:Key="SidebarTextBrush" Color="#ECF0F1"/>
    <SolidColorBrush x:Key="LowStockBg"       Color="#FFECEC"/>
    <SolidColorBrush x:Key="LowStockFg"       Color="#C0392B"/>
    <SolidColorBrush x:Key="PageBg"           Color="#F4F6F8"/>

    <!-- ===== زر أساسي (أزرق) ===== -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource AccentBrush}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Height"          Value="36"/>
        <Setter Property="Padding"         Value="16,0"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="4"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===== زر خطر (أحمر — للحذف) ===== -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
    </Style>

    <!-- ===== زر نجاح (أخضر — للإضافة/الحفظ/الدفع) ===== -->
    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
    </Style>

    <!-- ===== TextBox عام لكل المشروع ===== -->
    <Style TargetType="TextBox">
        <Setter Property="Height"                   Value="34"/>
        <Setter Property="Padding"                  Value="8,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="BorderBrush"              Value="#BDC3C7"/>
        <Setter Property="BorderThickness"          Value="1"/>
    </Style>

    <!-- ===== Label للنماذج (Add/Edit) ===== -->
    <Style x:Key="LabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"          Value="13"/>
        <Setter Property="Foreground"        Value="#555"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ===== DataGrid عام لكل الجداول ===== -->
    <Style TargetType="DataGrid">
        <Setter Property="AutoGenerateColumns"      Value="False"/>
        <Setter Property="CanUserAddRows"           Value="False"/>
        <Setter Property="CanUserDeleteRows"        Value="False"/>
        <Setter Property="SelectionMode"            Value="Single"/>
        <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
        <Setter Property="HeadersVisibility"        Value="Column"/>
        <Setter Property="RowHeight"                Value="36"/>
        <Setter Property="FontSize"                 Value="13"/>
        <Setter Property="BorderBrush"              Value="#DDD"/>
        <Setter Property="BorderThickness"          Value="1"/>
        <Setter Property="AlternatingRowBackground" Value="#F9F9F9"/>
    </Style>

    <!-- ===== زر الـ Sidebar (شفاف يتغير عند الـ Hover) ===== -->
    <Style x:Key="SidebarButton" TargetType="Button">
        <Setter Property="Background"                 Value="Transparent"/>
        <Setter Property="Foreground"                 Value="{StaticResource SidebarTextBrush}"/>
        <Setter Property="BorderThickness"            Value="0"/>
        <Setter Property="Height"                     Value="48"/>
        <Setter Property="FontSize"                   Value="14"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"                    Value="20,0"/>
        <Setter Property="Cursor"                     Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#3D5166"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
